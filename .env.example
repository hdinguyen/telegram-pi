# ============================================
# REQUIRED: Telegram Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================
# REQUIRED: AI Provider
# ============================================

# Choose ONE provider and set its API key:

# Option 1: OpenRouter (Recommended - access to multiple models)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: multimodal model used by the openrouter_vision image tool.
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
PI_MODEL_PROVIDER=openrouter
# For WEB TOOLS: Use models that support function calling:
PI_MODEL_ID=meta-llama/llama-3.1-8b-instruct:free
# FREE models with function calling: meta-llama/llama-3.1-8b-instruct:free
# PAID models with better function calling:
#   google/gemini-flash-1.5 (~$0.075/M tokens)
#   anthropic/claude-3-haiku (~$0.25/M tokens)
# ⚠️  NOT all free models support function calling (nvidia/nemotron doesn't work)

# Option 2: Anthropic Direct
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# PI_MODEL_PROVIDER=anthropic
# PI_MODEL_ID=claude-opus-4-5

# Option 3: OpenAI Direct
# OPENAI_API_KEY=sk-your-key-here
# PI_MODEL_PROVIDER=openai
# PI_MODEL_ID=gpt-4o

# Option 4: Google Gemini Direct
# GOOGLE_API_KEY=your-key-here
# PI_MODEL_PROVIDER=google
# PI_MODEL_ID=gemini-2.0-flash-exp

# ============================================
# OPTIONAL: Advanced Configuration
# ============================================

# Application
NODE_ENV=development
LOG_LEVEL=debug

# Bot Settings
TELEGRAM_BOT_USERNAME=your_bot_username
MAX_MESSAGE_HISTORY=50

# Private test allowlist (optional)
# When set, only this Telegram username (without @) can trigger the bot.
# Any other user who DMs or mentions the bot receives a "private test" notice.
# Leave empty to allow everyone.
AVAILABLE=nguyenh

# AI Agent Settings
PI_THINKING_LEVEL=medium
PI_MAX_RESPONSE_LENGTH=4000
PI_CONTEXT_MESSAGES=5
PI_GROUP_CONTEXT=true

# ============================================
# Session Persistence (per-group sessions)
# ============================================
# SQLite database mapping each Telegram group (chat_id) to its session file.
DATABASE_PATH=./data/sessions.db
# Directory where per-group conversation session files (JSONL) are stored.
SESSION_DIR=./data/sessions

# Web Tools Settings (Optional)
# Perplexity API for enhanced web search (recommended)
# Get your API key from: https://www.perplexity.ai/settings/api
# If not provided, falls back to DuckDuckGo (no API key needed)
PERPLEXITY_API_KEY=

# ============================================
# Notes
# ============================================
# This bot uses @earendil-works/pi-coding-agent with project extensions
# Features available:
#   - Chat, conversation, Q&A
#   - Image understanding/OCR via openrouter_vision tool
#   - Web search (via web_search tool)
#   - Content fetching (via fetch_content tool)
# Tool availability depends on the Pi resource loader/settings and selected model's tool-calling support.
# Web search providers:
#   - Perplexity AI (if PERPLEXITY_API_KEY set) - Best quality
#   - DuckDuckGo (free, no API key) - Fallback
